<script>
const form = document.getElementById("uploadForm");
const videoStream = document.getElementById("videoStream");
const statusBox = document.getElementById("statusBox");
const logBox = document.getElementById("logBox");

form.onsubmit = async (e) => {
    e.preventDefault();
    const formData = new FormData(form);

    statusBox.innerHTML = "Uploading & Processing...";
    statusBox.className = "status";

    // 1. Upload the file
    await fetch("/upload", {
        method: "POST",
        body: formData
    });

    // 2. Start the video stream immediately
    videoStream.src = "/video_feed?t=" + new Date().getTime();
    
    // Clear old logs
    logBox.innerHTML = "";
};

async function fetchStatus() {
    try {
        const response = await fetch("/violations");
        const data = await response.json();

        if (data.status === "SAFE") {
            statusBox.innerHTML = "🟢 GREEN ZONE - All Safe";
            statusBox.className = "status green";
        } else if (data.status) {
            statusBox.innerHTML = "🔴 " + data.status;
            statusBox.className = "status red";
            
            // 3. Add to log in the sidebar
            if (!logBox.innerText.includes(data.status)) {
                const entry = document.createElement("div");
                entry.style.marginBottom = "8px";
                entry.style.borderBottom = "1px solid #333";
                entry.innerHTML = `<strong>${new Date().toLocaleTimeString()}</strong>: ${data.status}`;
                logBox.prepend(entry);
            }
        }
    } catch (error) {
        console.error("Error fetching status:", error);
    }
    
    // 4. THE FIX: Recursive call ensures 2s gap AFTER request finishes
    setTimeout(fetchStatus, 2000); 
}

// Start the loop
fetchStatus();
</script>